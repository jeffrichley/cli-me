# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Temporary working directories
tmp/

# PDFs
*.pdf

# Local Claude settings
.claude/settings.local.json

# QA fixtures (generated/downloaded at test time)
qa/fixtures/*
!qa/fixtures/.gitkeep

# Per-skill QA fixtures (downloaded by fetch_*_fixtures.py scripts)
qa/pyannote/fixtures/single_speaker.wav
qa/pyannote/fixtures/two_speakers.wav

# R5 execution cache (per-skill, auto-generated)
.r5-cache.json
.gstack/

# Runtime lock files (agent scheduler state)
.claude/scheduled_tasks.lock
